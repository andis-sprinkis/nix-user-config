#!/usr/bin/env sh
set -eu

file_daemonpid="/tmp/${USER}_i3_auto_edge_snap_daemon_pid"
daemonpid="$(set +e; cat "$file_daemonpid" 2> "/dev/null"; set -e)"

if [ "$daemonpid" ] && kill -0 "$daemonpid" 2> "/dev/null"; then
  exit
else
  echo "${$}" > "$file_daemonpid"
fi

wm="${WAYLAND_DISPLAY:+"sway"}"
wm="${wm:-"i3"}"

case "$wm" in
  "sway")
    wm_cmd="swaymsg"
    win_edge_top_jq=".rect.y - .deco_rect.height"
    win_height_jq=".rect.height + .deco_rect.height"

    is_win_floating() { if [ "$(echo "$win" | sed "1q;d")" != "floating_con" ]; then return "1"; fi; }
  ;;
  "i3")
    wm_cmd="i3-msg"
    win_edge_top_jq=".rect.y"
    win_height_jq=".rect.height"

    is_win_floating() {
      case "$(echo "$win" | sed "2q;d")" in
        *"_off") return "1" ;;
      esac
    }
  ;;
esac

AS_on_AZ()  { [ "$AS" -eq "$AZ" ]; }
BS_on_BZ()  { [ "$BS" -eq "$BZ" ]; }
AS_in_AI()  { [ "$AS" -ge "$AZ" ] && [ "$AS" -lt "$AI" ]; }
AS_in_AO()  { [ "$AS" -ge "$AO" ] && [ "$AS" -lt "$AZ" ]; }
AS_in_BI()  { [ "$AS" -ge "$BI" ] && [ "$AS" -lt "$BZ" ]; }
AS_in_BO()  { [ "$AS" -ge "$BZ" ] && [ "$AS" -lt "$BO" ]; }
AS_in_S()   { [ "$AS" -ge "$AI" ] && [ "$AS" -lt "$BI" ]; }
AS_out_AO() { [ "$AS" -lt "$AO" ]; }
AS_out_BO() { [ "$AS" -ge "$BO" ]; }
BS_in_AI()  { [ "$BS" -ge "$AZ" ] && [ "$BS" -lt "$AI" ]; }
BS_in_AO()  { [ "$BS" -ge "$AO" ] && [ "$BS" -lt "$AZ" ]; }
BS_in_BI()  { [ "$BS" -lt "$BZ" ] && [ "$BS" -ge "$BI" ]; }
BS_in_BO()  { [ "$BS" -lt "$BO" ] && [ "$BS" -ge "$BZ" ]; }
BS_in_S()   { [ "$BS" -ge "$AI" ] && [ "$BS" -lt "$BI" ]; }
BS_out_AO() { [ "$BS" -lt "$AO" ]; }
BS_out_BO() { [ "$BS" -ge "$BO" ]; }

A() { echo "$AZ"; }
B() { echo "$((AS + BZ - BS))"; }
N() { echo "$AS"; }

A_or_B() {
  AS="$1" BS="$2" AZ="$3" BZ="$4" AI="$5" BI="$6" AO="$7" BO="$8"

  if AS_on_AZ || BS_on_BZ; then N; return; fi

  if AS_in_S; then
    if BS_in_S || BS_out_BO; then N; return; fi
    if BS_in_BI || BS_in_BO; then B; return; fi
  fi

  if AS_in_AI || AS_in_AO; then
    if BS_in_S || BS_out_BO || BS_in_AI; then A; return; fi

    if BS_in_BI; then
      if [ "$((AS - AZ))" -le "$((BZ - BS))" ]; then A; return; else B; return; fi
    fi

    if BS_in_BO; then
      if [ "$((AS - AZ))" -le "$((BS - BZ))" ]; then A; return; else B; return; fi
    fi
  fi

  if AS_in_AO && BS_out_AO; then A; return; fi

  if AS_out_AO; then
    if BS_in_BI || BS_in_BO; then B; return; fi
    if BS_in_S || BS_in_AI || BS_in_AO || BS_out_AO || BS_out_BO; then N; return; fi
  fi

  if AS_in_BI; then
    if BS_in_BO || BS_in_BI; then B; return; fi
    if BS_out_BO; then N; return; fi
  fi

  if AS_in_BO; then
    if BS_out_BO; then N; return; fi
    if BS_in_BO; then B; return; fi
  fi

  if AS_out_BO && BS_out_BO; then N; return; fi
}

win_jq=".. | select(.type?) | select(.focused) |
  .type,
  .floating,
  .fullscreen_mode,
  .rect.x, .rect.x + .rect.width,
  ${win_edge_top_jq}, ${win_edge_top_jq} + ${win_height_jq}"

ws_thr_x="(.rect.width / 20 | floor)"
ws_thr_y="(.rect.height / 20 | floor)"

ws_jq=".[] | select(.focused) |
  .rect.x, .rect.x + .rect.width, .rect.x + ${ws_thr_x}, .rect.x + .rect.width - ${ws_thr_x}, .rect.x - ${ws_thr_x}, .rect.x + .rect.width + ${ws_thr_x},
  .rect.y, .rect.y + .rect.height, .rect.y + ${ws_thr_y}, .rect.y + .rect.height - ${ws_thr_y}, .rect.y - ${ws_thr_y}, .rect.y + .rect.height + ${ws_thr_y}"

snap() {
  win="$($wm_cmd -r -t "get_tree" | jq -r "$win_jq")"

  if is_win_floating && [ "$(echo "$win" | sed "3q;d")" = "0" ]; then
    ws="$($wm_cmd -r -t "get_workspaces" | jq -r "$ws_jq")"

    # shellcheck disable=SC2046
    $wm_cmd -q "move absolute position $(A_or_B $(echo "$win" | sed "4,5!d") $(echo "$ws" | sed "1,6!d")) $(A_or_B $(echo "$win" | sed "6,7!d") $(echo "$ws" | sed "7,12!d"))"
  fi
}

while true; do
  snap 1> "/dev/null" 2> "/dev/null" & disown
  sleep "1"
done
