#!/usr/bin/env sh
set -euf
NL="
"

tmp="$(mktemp --suffix="_tmux_pane_copy")"

if [ -z "$tmp" ]; then
  exit "1"
fi

echo "# vi: nowrap ft=${NL}$(tmux capture-pane -pS -)" > "$tmp"

arg=""
case "$EDITOR" in
  "vi"|"vim"|"nvim"|"nano") arg="\+$(wc -l "$tmp")" ;;
esac

tmux split-pane "cat ${tmp} | ${EDITOR} ${arg}; rm ${tmp}"
