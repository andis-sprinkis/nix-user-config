#!/usr/bin/env sh
set -euf
IFS_="$IFS"
NL="
"

help_info() {
  script="$(basename "$0")"

  echo "NAME
    ${script} - Show disk utilization.

SYNOPSIS
    ${script} [-f]

DESCRIPTION
    Shows disk utilization.

    -f
        Shows utilization for all devices (including all of the 'tmpfs', 'efivarf', 'run', 'dev').

    -h
        Prints this message."
}

opt_has_f=""
while getopts fh name; do
  case "$name" in
    "f")
      opt_has_f="1"
    ;;
    "h")
      help_info
      exit
    ;;
    "?")
      help_info 1>&2
      exit "2"
    ;;
  esac
done

export LC_ALL="C"

fmt_reset="\x1b[0m" fmt_severity="\x1b[0;32m" fmt_mute="\x1b[0;90m"

human() {
  if [ "$1" -lt "1024" ]; then # <1MB
    echo "${1}KB"
    return
  fi

  if [ "$1" -lt "1048576" ]; then # <1GB
    ans="$(awk "BEGIN { printf \"%.1f\n\", ${1} / 1024 }")"
    echo "${ans%.0}MB"
    return
  fi

  if [ "$1" -lt "1073741824" ]; then # <1TB
    ans="$(awk "BEGIN { printf \"%.1f\n\", ${1} / 1048576 }")"
    echo "${ans%.0}GB"
    return
  fi

  if [ "$1" -lt "1099511627776" ]; then # <1PB
    ans="$(awk "BEGIN { printf \"%.1f\n\", ${1} / 1073741824 }")"
    echo "${ans%.0}TB"
    return
  fi

  if [ "$1" -lt "1125899906842624" ]; then # <1EB
    ans="$(awk "BEGIN { printf \"%.1f\n\", ${1} / 1099511627776 }")"
    echo "${ans%.0}PB"
    return
  fi
}

path_rev() {
  fp="$1" suf=""

  case "$1" in
    "//"*)
      fp="${1#"/"}"
      suf="\\"
    ;;
    *"@"*":/"*)
      fp="${1#*"@"*":"}"
      suf=":${1%":${fp}"}"
    ;;
  esac

  printf '%s\n' "$fp" | sed -e 's|/|/\n|g' | {
    rev=""

    IFS="$NL"
    while read -r "i"; do
      IFS="$IFS_"

      case "$i" in
        "/")
          rev="\\${rev}"
        ;;
        *"/")
          rev="\\${i%%/}${rev}"
        ;;
        *)
          rev="${i}${rev}"
        ;;
      esac
    done
    IFS="$IFS_"

    printf '%s\n' "${rev}${suf}"
  }
}

path_fmt() {
  case "$1" in
    "/")
      printf "${fmt_severity}%s${fmt_reset}\n" "\\"
    ;;
    "/"*)
      printf \
        "${fmt_severity}%s${fmt_reset}${fmt_mute}\\%s${fmt_reset}\n" "${1##*/}" "$(path_rev "${1%/*}")"
    ;;
    *)
      printf "${fmt_severity}%s${fmt_reset}\n" "$1"
    ;;
  esac
}

IFS="$NL"
df -P -k | tail -n "+2" | sort -k 6 | sed -e 's/[[:space:]]\+/;/g' | while read -r line; do
  IFS=";"
  # shellcheck disable=SC2086
  set -- $line
  IFS="$IFS_"

  fs="$1"
  mnt="$6"

  if [ -z "$opt_has_f" ]; then
    case "$fs" in
      "none"|"tmpfs"|"efivarfs"|"dev"|*".appimage")
        continue
      ;;
      "run")
        case "$mnt" in
          "/run/media/"*)
          ;;
          *)
            continue
          ;;
        esac
      ;;
      *)
        case "$mnt" in
          "/boot")
            continue
          ;;
        esac
      ;;
    esac
  fi

  size_b="$2"
  free_b="$4"
  use_pcnt="${5%%%}"

  free_pcnt="$((100 - use_pcnt))"

  fmt_severity="\x1b[0;32m"
  sym_severity=""

  if [ "$use_pcnt" -ge "90" ]; then
    fmt_severity="\x1b[0;31m"
    sym_severity="!"
  elif [ "$use_pcnt" -ge "60" ]; then
    fmt_severity="\x1b[0;33m"
    sym_severity="~"
  fi

  printf \
    "%s ${fmt_severity}Free %s%%%s %s${fmt_reset} ${fmt_mute}(%s %s)${fmt_reset}\n" \
    "$(path_fmt "$mnt")" "$free_pcnt" "$sym_severity" "$(human "$free_b")" "$(human "$size_b")" "$(path_rev "$fs")"
done
IFS="$IFS_"
