#!/usr/bin/env sh
set -euf
IFS_="$IFS"
NL="
"

script="$(basename "$0")"

help_info="NAME
    ${script} - Show disk utilization.

SYNOPSIS
    ${script} [-f]

DESCRIPTION
    Shows disk utilization.

    -f
        Shows utilization for all devices (including all of the 'tmpfs', 'efivarf', 'run', 'dev').

    -h
        Prints this message.
"

opt_has_f="0"
while getopts fh name; do
  case "$name" in
    "f")
      opt_has_f="1"
    ;;
    "h")
      echo "$help_info"
      exit
    ;;
    "?")
      echo "$help_info" 1>&2
      exit "2"
    ;;
  esac
done

export LC_ALL="C"

data="$(df -P -k | tail -n "+2" | sort -k 6 | sed -e 's/ \+/;/g')"

kb_mb="1024" kb_gb="1048576" kb_tb="1073741824" kb_pb="1099511627776" kb_eb="1125899906842624"

human() {
  if [ "$1" -lt "$kb_mb" ]; then printf "%sKB\n" "$1";  return; fi
  if [ "$1" -lt "$kb_gb" ]; then printf "%sMB\n" "$(echo "scale = 1; ${1} / ${kb_mb}" | bc | sed -e 's/\.0$//g')"; return; fi
  if [ "$1" -lt "$kb_tb" ]; then printf "%sGB\n" "$(echo "scale = 1; ${1} / ${kb_gb}" | bc | sed -e 's/\.0$//g')"; return; fi
  if [ "$1" -lt "$kb_pb" ]; then printf "%sTB\n" "$(echo "scale = 1; ${1} / ${kb_tb}" | bc | sed -e 's/\.0$//g')"; return; fi
  if [ "$1" -lt "$kb_eb" ]; then printf "%sPB\n" "$(echo "scale = 1; ${1} / ${kb_pb}" | bc | sed -e 's/\.0$//g')"; return; fi
}

mute() {
  printf "\x1b[0;90m%s\x1b[0m\n" "$1"
}

severity_fmt() {
  case "$SEVERITY" in
    "0")
      printf "\x1b[0;32m%s\x1b[0m\n" "$1"
    ;;
    "1")
      printf "\x1b[0;33m%s\x1b[0m\n" "$1"
    ;;
    "2")
      printf "\x1b[0;31m%s\x1b[0m\n" "$1"
    ;;
  esac
}

path_inv() {
  inv=""

  IFS="$NL"
  for i in $(printf '%s' "$1" | sed -e 's/\//\/\n/g'); do
    IFS="$IFS_"

    case "$i" in
      "/")
        inv="\\${inv}"
      ;;
      *"/")
        inv="\\${i%%/}${inv}"
      ;;
      *)
        inv="${i}${inv}"
      ;;
    esac
  done
  IFS="$IFS_"

  printf '%s\n' "$inv"
}

path_fmt() {
  case "$1" in
    "/")
      severity_fmt "\\"
    ;;
    "/"*)
      echo "$(severity_fmt "$(path_inv "/${1##*/}")")$(mute "$(path_inv "${1%/*}")")"
    ;;
    *)
      severity_fmt "$1"
    ;;
  esac
}

SEVERITY="0"

sym_severity() {
  case "$SEVERITY" in
    "0")
      echo ""
    ;;
    "1")
      echo "~"
    ;;
    "2")
      echo "!"
    ;;
  esac
}

i="1"
IFS="$NL"
for line in $data; do
  IFS="$IFS_"

  pnt_dev="$(echo "$line" | cut -d";" -f1)"
  pnt_mnt="$(echo "$line" | cut -d";" -f6)"

  if [ "$opt_has_f" = "0" ]; then
    case "$pnt_dev" in
      "none"|"tmpfs"|"efivarfs"|"dev"|*".appimage")
        continue
      ;;
      "run")
        case "$pnt_mnt" in
          "/run/media/"*)
          ;;
          *)
            continue
          ;;
        esac
      ;;
      *)
        case "$pnt_mnt" in
          "/boot")
            continue
          ;;
        esac
      ;;
    esac
  fi

  use_pcnt="$(echo "$line" | cut -d";" -f5)"
  use_pcnt="${use_pcnt%%%}"
  free_pcnt="$((100 - use_pcnt))"
  # use_b="$(echo "$line" | cut -d";" -f3)"
  free_b="$(echo "$line" | cut -d";" -f4)"
  size_b="$(echo "$line" | cut -d";" -f2)"

  if [ "$use_pcnt" -ge "90" ]; then
    SEVERITY="2"
  elif [ "$use_pcnt" -ge "60" ]; then
    SEVERITY="1"
  else
    SEVERITY="0"
  fi

  echo "$(path_fmt "$pnt_mnt") $(severity_fmt "Free ${free_pcnt}%$(sym_severity) $(human "$free_b")") $(mute "($(human "$size_b") $(path_inv "${pnt_dev}"))")"

  i="$((i + 1))"
done
IFS="$IFS_"
