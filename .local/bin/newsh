#!/usr/bin/env sh
set -euff

if [ -z "${1:-""}" ]; then
  exit "1"
fi

fpath="$1"

if [ -e "$fpath" ]; then
  exit "2"
fi

touch "$fpath"

if [ ! -r "$fpath" ]; then
  exit "3"
fi

fname="$(basename "$fpath")"

template="#!/usr/bin/env sh
set -euff
# IFS_=\"\$IFS\"
# NL=\"
# \"
# dir=\"\$(cd -P -- \"\$(dirname -- \"\$0\")\" && pwd -P)\"
# script=\"\$(basename \"\$0\")\"
#
# if [ -z \"\${1:-\"\"}\" ]; then
#   echo \"\${script}: Requires an argument.\" 2>&1
#   exit \"1\"
# fi
#
# if [ \"\${1:-\"\"}\" ]; then
#   echo \"\$1\"
# fi
#
# while read -r l; do
#   echo \"\$l\"
#   continue
# done
#
# set -f; IFS=\" \"
# for i in \$items; do
#   set +f; IFS=\"\$IFS_\"
#
#   command ...
# done
# set +f; IFS=\"\$IFS_\"
"

echo "$template" > "$fpath"

chmod "+x" "$fpath"

dirpath="$(dirname "$(readlink -f "$fpath")")"

dircmd() {
  printf 'cd "%s"; ls "%s"' "$dirpath" "$fname"
}

if [ "${WAYLAND_DISPLAY:-""}" ] && command -v "wl-copy" 1> "/dev/null" 2> "/dev/null"; then
  dircmd | wl-copy
fi

if [ "${DISPLAY:-""}" ] && [ -z "${WAYLAND_DISPLAY:-""}" ] && command -v "xclip" 1> "/dev/null" 2> "/dev/null"; then
  dircmd | xclip -sel "clipboard"
fi

if command -v "pbcopy" 1> "/dev/null" 2> "/dev/null"; then
  dircmd | pbcopy
fi

case "${EDITOR:-""}" in
  "vi"|"vim"|"nvim"|"nano")
    $EDITOR "+$(echo "$template" | wc -l)" "$fpath"
  ;;
  "")
    echo "$fpath"
    exit
  ;;
  *)
    $EDITOR "$fpath"
  ;;
esac
