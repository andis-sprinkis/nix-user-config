#!/usr/bin/env sh
set -euf

if [ -z "${*:-""}" ] || [ -z "${1:-""}" ]; then
  exit "1"
fi

tmp="$(mktemp)"

printf '%s\n' "$*" | qrencode -t PNG -s "256" -o - > "$tmp"

# shellcheck disable=SC3028
# shellcheck disable=SC3044
case "${OSTYPE:-"$(uname)"}" in
  [dD]"arwin"*)
    open "$tmp" 1>/dev/null 2>/dev/null & disown
  ;;
  *)
    xdg-open "$tmp" 1>/dev/null 2>/dev/null & disown
  ;;
esac
