#!/usr/bin/env sh
set -eu

FPATH_INPUT="$1"
FPATH="$(set +e; readlink -f "$FPATH_INPUT"; set -e)"
MIME="$(file --mime-type --brief "$FPATH")"
BRIEF="$(file --brief "$FPATH")"
W_CHR="${2:-""}"
H_CHR="${3:-""}"
FPATH_THUMB=""

trap "exit" "PIPE"

find_util() {
  if ! command -v "$1" 1>/dev/null 2>/dev/null; then
    echo "$(basename "$0"): '${1}' utility not found."
    return "1"
  fi
}

thumb_cache_create() {
  dir_cache_thumb="${XDG_CACHE_HOME:-"${HOME}/.cache"}/previewer/thumbnails"

  hash="$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$FPATH" | sha1sum)"
  hash="${hash%%"  -"}"

  FPATH_THUMB="${dir_cache_thumb}/${hash}"

  if [ -d "$dir_cache_thumb" ] || mkdir -p "$dir_cache_thumb"; then
    return "0"
  fi

  return "1"
}

print_stat() {
  if [ -L "$FPATH_INPUT" ]; then
    stat "$FPATH_INPUT"

    if [ -e "$FPATH" ]; then
      echo
      stat "$FPATH"
    fi
  else
    stat "$FPATH"
  fi
}

print_symlink() {
  if [ ! -L "$FPATH_INPUT" ]; then
    return "0"
  fi

  if [ -z "$FPATH" ]; then
    printf "\x1b[0;31;1m%s\x1b[0m\n\n" "Broken or inaccessible symbolic link."
    print_stat
    exit "0"
  fi

  if [ ! -e "$FPATH" ]; then
    printf "\x1b[0;31;1m%s\x1b[0m\n%s\n\n" "Broken or inaccessible symbolic link to:" "$FPATH"
    print_stat
    exit "0"
  fi

  printf "\x1b[0;1m%s\x1b[0m\n%s\n\n" "Symbolic link to:" "$FPATH"
}

print_hardlink() {
  if [ "$FPATH" ] && [ -e "$FPATH" ]; then
    links_count="$(stat -c '%h' -- "$FPATH")"

    if [ "$links_count" -gt "1" ]; then
      echo "${links_count} hard links"
    fi
  fi
}

print_strings() {
  if find_util "strings"; then
    strings "$FPATH"
  else
    return "1"
  fi
}

print_mediainfo() {
  if find_util "mediainfo"; then
    out="$(set +e; mediainfo "$FPATH" | head -n -2 | sed -e 's/ *: /: /g' -e '/^General$/d'; set -e)"
    if [ "$out" ]; then printf '%s\n' "$out" | ansifilter; fi
  else
    return "1"
  fi
}

print_exiftool() {
  if find_util "exiftool"; then
    out="$(set +e; exiftool -s2 "$FPATH"; set -e)"
    if [ "$out" ]; then printf '%s\n' "$out" | ansifilter; fi
  else
    return "1"
  fi
}

print_chafa() {
  if find_util "chafa"; then
    if [ -f "$1" ]; then
      if [ ! -s "$1" ]; then
        return "2"
      fi

      lines="$(tput lines)"
      columns="$(tput cols)"

      chafa \
        --format "symbols" \
        --font-ratio "1/2" \
        --animate "off" \
        --polite "on" \
        --work "1" \
        -s "${W_CHR:-"$columns"}x${H_CHR:-"$lines"}" \
        "$1"
    fi
  else
    return "1"
  fi
}

print_als() {
  if find_util "als"; then
    out="$(set +e; als --format="$1" -- "$FPATH"; set -e)"
    if [ "$out" ]; then printf '%s\n' "$out" | ansifilter; fi
  else
    return "1"
  fi
}

print_bat() {
  if find_util "bat"; then
    ansifilter "$FPATH" | bat --color=always --italic-text=always --style=plain --file-name "$FPATH"
  else
    return "1"
  fi
}

print_hexdump() {
  if find_util "hexdump"; then
    bytes="1048576"

    echo "

First ${bytes} bytes or less:"

    hexdump -C -n "$bytes" "$FPATH"
  fi
}

print_mime() {
  if [ "$MIME" ]; then
    if [ "$BRIEF" ] && [ "$MIME" != "$BRIEF" ]; then
      echo "$MIME (${BRIEF})"
    else
      echo "$MIME"
    fi
  fi
}

print_lines_count() {
  lines_count="$(wc -l "$FPATH" | cut -d" " -f1)"

  case "$lines_count" in
    "1")
      echo "1 line:"
    ;;
    "0")
    ;;
    *)
      echo "${lines_count} lines:"
    ;;
  esac
}

if ! find_util "ansifilter"; then exit "0"; fi

print_mime

if [ ! -r "$FPATH_INPUT" ]; then
  echo "Not readable."
  echo
fi

print_symlink
print_hardlink

if [ -z "$FPATH" ]; then
  exit "0"
fi

if [ ! -r "$FPATH" ]; then
  echo "Not readable."
  echo

  set +e; print_stat 2> "/dev/null"; set -e;

  exit "0"
fi

case "$MIME" in
  application/eps|application/pdf|application/postscript|application/x-eps|image/x-eps)
    if thumb_cache_create; then
      if [ ! -f "${FPATH_THUMB}.jpg" ]; then
        if find_util "pdftoppm"; then
          if pdftoppm -jpeg -jpegopt quality=50 -f "1" -singlefile "$1" "$FPATH_THUMB"; then
            if print_chafa "${FPATH_THUMB}.jpg"; then
              echo
            fi
          fi
        fi
      else
        if print_chafa "${FPATH_THUMB}.jpg"; then
          echo
        fi
      fi
    fi

    if find_util "pdfinfo"; then
      out="$(set +e; pdfinfo "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s\n\n' "$out" | ansifilter; fi
    fi

    if find_util "pdfsig"; then
      out="$(set +e; pdfsig "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s\n\n' "$out" | ansifilter; fi
    fi

    if find_util "pdftotext"; then
      out="$(set +e; pdftotext -l "2" -nopgbrk -q -- "$FPATH" -; set -e)"
      if [ "$out" ]; then printf '%s' "$out" | ansifilter; fi
    fi
  ;;
  image/vnd.djvu*)
    if thumb_cache_create; then
      if [ ! -f "${FPATH_THUMB}.jpg" ]; then
        if find_util "ddjvu" && find_util "magick"; then
          if ddjvu -format=ppm -page=1 "$1" | magick "-" "${FPATH_THUMB}.jpg"; then
            if print_chafa "${FPATH_THUMB}.jpg"; then
              echo
            fi
          fi
        fi
      else
        if print_chafa "${FPATH_THUMB}.jpg"; then
          echo
        fi
      fi
    fi
  ;;
  application/vnd.openxmlformats-officedocument.wordprocessingml.document)
    if find_util "docx2txt"; then
      out="$(set +e; docx2txt "$FPATH" -; set -e)"
      if [ "$out" ]; then printf '%s\n' "$out" | ansifilter; fi
    fi

    print_als "zip"
  ;;
  application/zip|application/epub+zip|application/java-archive|*openxmlformats-officedocument*)
    print_als "zip"
  ;;
  "application/x-compressed-tar")
    print_als "tar+gzip"
  ;;
  "application/x-bzip1-compressed-tar")
    print_als "tar+bzip"
  ;;
  "application/x-bzip2-compressed-tar")
    print_als "tar+bzip2"
  ;;
  "application/x-tarz")
    print_als "tar+compress"
  ;;
  "application/x-tzo")
    print_als "tar+lzop"
  ;;
  "application/x-lzip-compressed-tar"|"application/x-lzma-compressed-tar")
    print_als "tar+lzip"
  ;;
  "application/x-xz-compressed-tar")
    print_als "tar+xz"
  ;;
  "application/x-tar")
    print_als "tar"
  ;;
  "application/vnd.rar")
    print_als "rar"
  ;;
  "application/x-lha")
    print_als "lha"
  ;;
  "application/x-ace")
    print_als "ace"
  ;;
  "application/x-archive")
    print_als "ar"
  ;;
  "application/x-arj")
    print_als "arj"
  ;;
  "application/vnd.ms-cab-compressed")
    print_als "cab"
  ;;
  "application/x-cpio")
    print_als "cpio"
  ;;
  "application/x-7z-compressed")
    if find_util "als"; then
      # Passing an empty password to avoid a lock-up.
      out="$(set +e; als --format=7z --format-option=-p="" -- "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s' "$out" | ansifilter; fi
    fi
  ;;
  application/gzip|application/x-bzip1|application/x-bzip2|application/x-compress|application/x-lzma|application/x-lzop|application/x-lzip|application/x-xz|application/x-lrzip|application/x-alz)
    # Archive types that 'als' recognizes, but cannot list.
    print_stat
  ;;
  image/svg+xml)
    if print_chafa "$FPATH"; then
      echo
    fi

    print_lines_count
    print_bat
  ;;
  image/*)
    if print_chafa "$FPATH"; then
      echo
    fi

    print_exiftool
  ;;
  video/*|application/x-ogm-video)
    if thumb_cache_create; then
      if [ ! -f "${FPATH_THUMB}.jpg" ]; then
        if find_util "ffmpegthumbnailer"; then
          if ffmpegthumbnailer -i "$1" -o "${FPATH_THUMB}.jpg" -s "0" -q "5"; then
            if print_chafa "${FPATH_THUMB}.jpg"; then
              echo
            fi
          fi
        fi
      else
        if print_chafa "${FPATH_THUMB}.jpg"; then
          echo
        fi
      fi
    fi

    print_mediainfo
  ;;
  *opendocument*)
    if find_util "odt2txt"; then
      out="$(set +e; odt2txt "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s\n' "$out" | ansifilter; fi
    fi

    print_als "zip"
  ;;
  audio/*|application/mxf|application/ogg|application/sdp|application/smil|application/streamingmedia|application/vnd.apple.mpegurl|application/vnd.ms-asf|application/vnd.rn-realmedia-vbr|application/vnd.rn-realmedia|application/x-cue|application/x-extension-m4a|application/x-extension-mp4|application/x-matroska|application/x-mpegurl|application/x-ogg|application/x-ogm-audio|application/x-ogm|application/x-shorten|application/x-smil|application/x-streamingmedia)
    if thumb_cache_create; then
      if [ ! -f "${FPATH_THUMB}.jpg" ]; then
        if find_util "exiftool"; then
          if exiftool -b -picture -W "${FPATH_THUMB}.jpg" "$FPATH" 1> /dev/null; then
            if print_chafa "${FPATH_THUMB}.jpg"; then
              echo
            fi
          elif exiftool -b -coverart -W "${FPATH_THUMB}.jpg" "$FPATH" 1> /dev/null; then
            if print_chafa "${FPATH_THUMB}.jpg"; then
              echo
            fi
          fi
        fi
      else
        if print_chafa "${FPATH_THUMB}.jpg"; then
          echo
        fi
      fi
    fi

    if print_mediainfo; then
      echo
    fi

    if [ "$MIME" = "audio/mpeg" ] && find_util "mpg123-id3dump"; then
      out="$(set +e; mpg123-id3dump -- "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s' "$out" | ansifilter; fi
    fi
  ;;
  application/vnd.sqlite*)
    if find_util "sqlite3"; then
      out="$(set +e; sqlite3 "$FPATH" '.tables'; set -e)"
      if [ "$out" ]; then printf '.tables:%s\n' "$out" | ansifilter; fi
    fi

    print_strings
  ;;
  application/x-executable|application/x-pie-executable|application/x-object|application/x-sharedlib)
    if find_util "readelf"; then
      out="$(set +e; readelf -a "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s' "$out" | ansifilter; fi
    fi
  ;;
  inode/directory)
    if [ -r "$FPATH" ]; then
      if find_util "mountpoint"; then
        if mountpoint -q -- "$FPATH"; then
          dev="$(set +e; grep " ${FPATH} " "/proc/mounts" | cut -d" " -f1; set -e)"

          if [ "$dev" ]; then
            printf "\x1b[0;1m%s\x1b[0m\n%s\n" "Mount point of:" "${dev}"
            echo
            df -h "$dev"
          fi
        fi
      fi

      echo

      # shellcheck disable=SC2010
      if ls --version 2> "/dev/null" | grep -q "GNU"; then
        ls -lahAFNX --color=always --group-directories-first --time-style=long-iso "$FPATH"
      else
        ls -la "$FPATH"
      fi
    else
      echo
      echo "Read permission denied."
    fi

    echo
    print_stat
  ;;
  inode/*)
    print_stat
  ;;
  application/octet-stream)
    # TODO: re-try by file extension
    print_strings
    print_hexdump
    echo
    print_stat
  ;;
  application/vnd.microsoft.portable-executable|application/x-dosexec*|application/x-ole-storage)
    print_strings
    print_hexdump
  ;;
  application/x-coredump)
    print_hexdump
    echo
    print_stat
  ;;
  application/x-linux-kernel)
    if [ "$BRIEF" ]; then
      echo "$BRIEF" | tr ',' '\n' | sed 's/^ //g'
    fi
  ;;
  font/*|application/x-font-*|application/vnd.ms-opentype)
    print_exiftool
  ;;
  application/vnd.debian.binary-package|application/x-rpm)
    if find_util "als"; then
      out="$(set +e; als -- "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s\n' "$out" | ansifilter; fi
    fi

    print_strings
  ;;
  application/x-bittorrent|application/x-lz4+json|application/x-mobipocket-ebook)
    print_strings
  ;;
  application/x-iso9660-image)
    if find_util "iso-info"; then
      out="$(set +e; iso-info --no-header -U "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s\n' "$out" | ansifilter; fi
      out="$(set +e; iso-info --no-header -l "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s' "$out" | ansifilter; fi
    fi
  ;;
  text/x-ssh-public-key|application/x-pem-file)
    if find_util "ssh-keygen"; then
      out="$(set +e; ssh-keygen -lv -f "$FPATH"; set -e)"
      if [ "$out" ]; then printf '%s' "$out" | ansifilter; fi
    fi

    print_lines_count
    print_bat
  ;;
  text/html)
    if [ "${FPATH##*.}" = "svg" ]; then
      if print_chafa "$FPATH"; then
        echo
      fi
    fi

    print_lines_count
    print_bat
  ;;
  *)
    print_lines_count

    if ! print_bat; then
      print_strings
      print_hexdump
      echo
      print_stat
    fi
  ;;
esac

exit "0"
