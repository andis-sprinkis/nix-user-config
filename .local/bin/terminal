#!/usr/bin/env sh
set -euf

# shellcheck disable=SC3028
case "${OSTYPE:-"$(uname)"}" in
  [lL]"inux"*)
    if [ "${WAYLAND_DISPLAY:-""}" ]; then
      if pidof -q "foot"; then
        exec footclient "$@"
      fi

      exec foot "$@"
    fi

    if [ "${DISPLAY:-""}" ] && [ -z "${WAYLAND_DISPLAY:-""}" ]; then
      if pidof -q "ghostty"; then
        exec ghostty "+new-window" "$@"
      fi

      exec ghostty "$@"
    fi

    exit "1"
  ;;
  *)
    exec ghostty "+new-window" "$@"
  ;;
esac
