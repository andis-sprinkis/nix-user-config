#!/usr/bin/env sh
set -euf

# shellcheck disable=SC3028
case "${OSTYPE:-"$(uname)"}" in
  [lL]"inux"*)
    if [ "${WAYLAND_DISPLAY:-""}" ]; then
      if [ "${SSH_CLIENT:-""}" ]; then
        exec foot "$@"
      fi

      # TODO: launch foot server
      exec footclient "$@"
    fi

    if [ "${DISPLAY:-""}" ] && [ -z "${WAYLAND_DISPLAY:-""}" ]; then
      if pidof -q "ghostty"; then
        exec ghostty "+new-window" "$@"
      fi

      # TODO: launch ghostty server
      exec ghostty "$@"
    fi

    exit "1"
  ;;
  *)
    exec ghostty "$@"
  ;;
esac
