#!/usr/bin/env sh

# shellcheck disable=SC3028
case "${OSTYPE:-"$(uname)"}" in
  [lL]"inux"*)
    if [ "${WAYLAND_DISPLAY:-""}" ]; then
      exec footclient "$@"
    fi

    if [ "${DISPLAY:-""}" ] && [ -z "${WAYLAND_DISPLAY:-""}" ]; then
      # exec kitty --single-instance "$@"
      exec ghostty "$@"
    fi

    exit "1"
  ;;
  *)
    # exec kitty --single-instance "$@"
    exec ghostty "$@"
  ;;
esac

exit "2"
