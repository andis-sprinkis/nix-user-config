#!/usr/bin/env sh
set -euf

# shellcheck disable=SC3028
case "${OSTYPE:-"$(uname)"}" in
  [lL]"inux"*)
    if [ "${WAYLAND_DISPLAY:-""}" ]; then
      if [ "${SSH_CLIENT:-""}${SSH_CONNECITON:-""}${SSH_TTY:-""}" ]; then
        exec foot "$@"
      fi

      # TODO: launch foot server
      exec footclient "$@"
    fi

    if [ "${DISPLAY:-""}" ] && [ -z "${WAYLAND_DISPLAY:-""}" ]; then
      # TODO: launch ghostty server
      exec ghostty "$@"
    fi

    exit "1"
  ;;
  *)
    exec ghostty "$@"
  ;;
esac
