#!/usr/bin/env sh
set -euf
NL="
"

warnings=""
directory="$PWD"

if [ "${1:-""}" ]; then
  directory="$(readlink -f "$1")"
fi

if [ -e "$directory" ] && [ ! -d "$directory" ]; then
  warnings="${warnings}${warnings:+"$NL"}Warning: ${directory} is not a directory"
fi

if [ -e "$directory" ] && [ ! -r "$directory" ]; then
  warnings="${warnings}${warnings:+"$NL"}Warning: ${directory} does not have a read access for the current user"
fi

if [ ! -e "$directory" ]; then
  warnings="${warnings}${warnings:+"$NL"}Warning: ${directory} does not exist"
fi

if [ "$warnings" ]; then
  printf "\x1b[0;33m%s\x1b[0m\n\n" "$warnings"
fi

menu_display="" menu_values="" ifcs_count="0"
for ifc in $(ifconfig | sed -e '/^[a-z0-9]*:.*$/!d' -e 's/:.*$//g' | paste -s -d ' ' -); do
  ip="$(ifconfig "$ifc" | sed -e 's/^[[:space:]]*//g' | grep '^inet ' | cut -d ' ' -f2)"

  if [ "$ip" ]; then
    is_localhost=""
    if [ "$ip" = "127.0.0.1" ]; then
      is_localhost="1"
    fi

    ifcs_count=$((ifcs_count + 1))
    menu_display="${menu_display}${menu_display:+"$NL"}${ifcs_count}. ${ifc}: ${ip}${is_localhost:+ (default)}"
    menu_values="${menu_values}${menu_values:+"$NL"}${ifc} ${ip}"
  fi
done

if [ "$ifcs_count" = "0" ]; then
  echo "No available network interfaces found." >&2
  exit "1"
fi

sel_idx=""
while true; do
  printf '%s\n%s\n> ' "Interface:" "$menu_display"
  read -r sel_idx

  case "$sel_idx" in
    *[!0123456789]*)
      printf '%s\n\n' "Invalid selection"
      continue
    ;;
    '')
      sel_idx="1"
      break
    ;;
    *)
      if [ "$sel_idx" -lt "1" ] || [ "$sel_idx" -gt "$ifcs_count" ]; then
        printf '%s\n\n' "Invalid selection"
        continue
      fi

      break
    ;;
  esac
done

menu_display_sel="$(echo "$menu_display" | sed "${sel_idx}q;d")"
menu_value_sel="$(echo "$menu_values" | sed "${sel_idx}q;d")"

ifc="$(echo "$menu_value_sel" | cut -d" " -f1)"
ip="$(echo "$menu_value_sel" | cut -d" " -f2)"
port="${PORT:-"8080"}"

test_port() {
  python3 <<python
import socket
import sys

try:
  with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.settimeout(3)
    if sock.connect_ex(("$1", $2)) == 0:
      sys.exit(3)
    sys.exit(0)
except OSError:
  sys.exit(1)
python
}

set +e
test_port "$ip" "$port"
exit="$?"
set -e

if [ "$exit" != "0" ]; then
  while true; do
    newport="$(awk 'BEGIN { srand(); print int(1024 + rand() * 49151) }')"

    set +e
    test_port "$ip" "$newport"
    exit="$?"
    set -e

    if [ "$exit" = "0" ]; then
      port="$newport"
      break
    fi
  done
fi

url="http://${ip}:${port}/";

echo "Selected: ${menu_display_sel}$NL"

if command -v "qrencode" 1> "/dev/null" 2> "/dev/null"; then
  echo "$url" | qrencode -t "ansiutf8"
fi

printf "URL: \x1b[0;35m%s\x1b[0m\n" "${url}"

if [ "${WAYLAND_DISPLAY:-""}" ] && command -v "wl-copy" 1> "/dev/null" 2> "/dev/null"; then
  echo "$url" | wl-copy
  echo "Copied URL to clipboard with 'wl-copy'"
fi

if [ "${DISPLAY:-""}" ] && [ -z "${WAYLAND_DISPLAY:-""}" ] && command -v "xclip" 1> "/dev/null" 2> "/dev/null"; then
  echo "$url" | xclip -sel "clipboard"
  echo "Copied URL to clipboard with 'xclip'"
fi

if command -v "pbcopy" 1> "/dev/null" 2> "/dev/null"; then
  echo "$url" | pbcopy;
  echo "Copied URL to clipboard with 'pb-copy'"
fi

# shellcheck disable=SC3028
case "${OSTYPE:-"$(uname)"}" in
  [Dd]"arwin"*)
    echo "Opening URL with 'open'"
    (
      sleep "1"
      open "$url"
    ) &
  ;;
  *)
    echo "Opening URL with 'xdg-open'"
    (
      sleep "1"
      xdg-open "$url"
    ) &
  ;;
esac

echo "${NL}Interface: ${ifc} | IP: ${ip} | Port: ${port} | Directory: ${directory}"

if [ "$warnings" ]; then
  printf "\x1b[0;33m%s\x1b[0m\n" "$warnings"
fi

echo "${NL}The server log:"

python3 -m "http.server" --bind "$ip" --directory "$directory" "$port"

trap "echo 'Suspending...'" TSTP
